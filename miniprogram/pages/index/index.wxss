/* pages/index/index.wxss */
.page { padding: 12px; background: #F5F4F0; min-height: 100vh; box-sizing: border-box; }

.err-tip, .empty-tip {
  padding: 12px;
  margin-bottom: 8px;
  font-size: 12px;
  color: #993C1D;
  background: #FAECE7;
  border-radius: 8px;
  text-align: center;
}

.cimg-mark { font-size: 28px; opacity: 0.35; }

.chips { white-space: nowrap; margin-bottom: 10px; }
.chip { display: inline-block; padding: 4px 12px; border-radius: 14px; font-size: 11px; border: 0.5px solid #ccc; color: #666; background: #fff; margin-right: 6px; }
.chip-on { background: #E6F1FB; border-color: #185FA5; color: #0C447C; font-weight: 500; }

.sec-hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.sec-title { font-size: 12px; font-weight: 500; color: #666; }
.sec-more { display: flex; align-items: center; gap: 3px; font-size: 11px; color: #185FA5; }

.card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.mcard { background: #fff; border-radius: 10px; border: 0.5px solid #e8e8e4; overflow: hidden; }
.cimg { height: 80px; position: relative; overflow: hidden; }
.cimg-placeholder { position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; }
.cimg-icon { font-size: 28px; opacity: 0.35; }
.cimg-src { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }
.cimg-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }
.cbadge { position: absolute; top: 6px; left: 6px; font-size: 9px; padding: 2px 6px; border-radius: 8px; font-weight: 500; }
.alt-badge { position: absolute; bottom: 6px; left: 6px; font-size: 9px; padding: 2px 6px; border-radius: 8px; background: rgba(0,0,0,.06); color: #555; }
.ccheckin { position: absolute; top: 6px; right: 6px; font-size: 9px; padding: 2px 6px; border-radius: 8px; background: rgba(230, 241, 251, 0.9); color: #0C447C; border: 0.5px solid #85B7EB; display: flex; align-items: center; gap: 2px; }
.cfav { position: absolute; bottom: 6px; right: 6px; width: 22px; height: 22px; border-radius: 50%; background: rgba(255,255,255,.9); display: flex; align-items: center; justify-content: center; border: 0.5px solid #e0dfd8; }
.cfav-on { color: #D85A30; }

.cbody { padding: 7px 8px 9px; }
.ctitle { font-size: 12px; font-weight: 500; color: #222; display: block; }
.csub { display: flex; align-items: center; gap: 3px; font-size: 10px; color: #999; margin-top: 2px; }
.cweather { display: flex; align-items: center; justify-content: space-between; margin-top: 5px; font-size: 11px; color: #666; }
.wlabel { display: flex; align-items: center; gap: 3px; font-size: 11px; color: #666; min-width: 0; flex: 1; }
.wtext { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wicon { color: #378ADD; }
.wtemp { font-size: 12px; font-weight: 500; color: #222; }

/* 背景色方案 */
.bg-green  { background: #EAF3DE; } .color-green  { color: #3B6D11; }
.bg-teal   { background: #E1F5EE; } .color-teal   { color: #0F6E56; }
.bg-purple { background: #EEEDFE; } .color-purple { color: #534AB7; }
.bg-blue   { background: #E6F1FB; } .color-blue   { color: #185FA5; }
.bg-amber  { background: #FAEEDA; } .color-amber  { color: #854F0B; }
.bg-coral  { background: #FAECE7; } .color-coral  { color: #993C1D; }
.bg-gray   { background: #F1EFE8; } .color-gray   { color: #5F5E5A; }

.badge-green  { background: #EAF3DE; color: #3B6D11; border: 0.5px solid #97C459; }
.badge-teal   { background: #E1F5EE; color: #0F6E56; border: 0.5px solid #5DCAA5; }
.badge-purple { background: #EEEDFE; color: #534AB7; border: 0.5px solid #AFA9EC; }
.badge-blue   { background: #E6F1FB; color: #185FA5; border: 0.5px solid #85B7EB; }
.badge-amber  { background: #FAEEDA; color: #854F0B; border: 0.5px solid #EF9F27; }
.badge-coral  { background: #FAECE7; color: #993C1D; border: 0.5px solid #F0997B; }
.badge-gray   { background: #F1EFE8; color: #5F5E5A; border: 0.5px solid #B4B2A9; }

/* 字体图标尺寸 */
.icon-xs { font-size: 10px; }
.icon-s  { font-size: 13px; }
.icon-m  { font-size: 16px; }
.icon-hero { font-size: 28px; opacity: .35; }
