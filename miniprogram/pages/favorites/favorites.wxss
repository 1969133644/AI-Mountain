.page { padding: 12px; background: #F5F4F0; min-height: 100vh; }

.sec-hd { margin-bottom: 10px; }
.sec-title { font-size: 13px; font-weight: 500; color: #666; }

.empty {
  padding: 40px 16px;
  text-align: center;
  font-size: 12px;
  color: #aaa;
}

.fav-item {
  background: #fff;
  border-radius: 8px;
  border: 0.5px solid #e8e5d8;
  padding: 12px;
  margin-bottom: 8px;
}

.fav-name { font-size: 14px; font-weight: 500; color: #222; display: block; }
.fav-sub { font-size: 11px; color: #999; margin-top: 4px; display: block; }
