/* pages/detail/detail.wxss — 对齐设计稿详情页 */
.page-wrap { min-height: 100vh; }

.page {
  padding: 12px;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  background: #F5F4F0;
  min-height: 100vh;
  box-sizing: border-box;
}

.back-row {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 8px;
  font-size: 11px;
  color: #aaa;
}

.back-text { color: #aaa; }

.hero {
  height: 120px;
  border-radius: 10px;
  position: relative;
  border: 0.5px solid rgba(0, 0, 0, 0.06);
  overflow: hidden;
  margin-bottom: 8px;
}

.hero-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon {
  font-size: 36px;
  opacity: 0.35;
}

.hero-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.3;
}

.hero-bot {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10px 12px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.hero-name {
  font-size: 16px;
  font-weight: 500;
  color: #222;
  display: block;
}

.hero-loc {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 10px;
  color: #666;
  margin-top: 2px;
}

.bg-green .hero-name { color: #27500A; }
.bg-green .hero-loc { color: #3B6D11; }
.bg-teal .hero-name { color: #0F6E56; }
.bg-teal .hero-loc { color: #0F6E56; }
.bg-purple .hero-name { color: #534AB7; }
.bg-blue .hero-name { color: #0C447C; }
.bg-amber .hero-name { color: #854F0B; }
.bg-coral .hero-name { color: #993C1D; }

.hero-actions { display: flex; gap: 6px; }

.hbtn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #fff;
  border: 0.5px solid #e0dfd8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hbtn-on .ti-heart { color: #D85A30; }

.info4 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  margin-bottom: 8px;
}

.icell {
  background: #fff;
  border-radius: 8px;
  padding: 10px;
  border: 0.5px solid #e8e5d8;
}

.ilbl { font-size: 10px; color: #bbb; display: block; }
.ival { font-size: 13px; font-weight: 500; color: #222; margin-top: 2px; display: block; }

.wx-card {
  background: #fff;
  border-radius: 10px;
  border: 0.5px solid #e8e5d8;
  padding: 12px;
  margin-bottom: 8px;
}

.wx-hd {
  font-size: 11px;
  font-weight: 500;
  color: #888;
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 8px;
}

.wx-hd-sub { margin-top: 4px; }

.wx-now-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-bottom: 10px;
  border-bottom: 0.5px solid #efefeb;
  margin-bottom: 10px;
}

.big-temp {
  font-size: 28px;
  font-weight: 500;
  color: #222;
  line-height: 1;
}

.wx-desc-main {
  font-size: 12px;
  color: #444;
  display: block;
  margin-bottom: 2px;
}

.wx-desc-sub {
  font-size: 10px;
  color: #888;
  line-height: 1.6;
  display: block;
}

.wx-loading {
  font-size: 11px;
  color: #aaa;
  padding: 8px 0;
}

.fc-scroll {
  white-space: nowrap;
  width: 100%;
}

.fcd {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  min-width: 50px;
  padding: 8px 4px;
  border-radius: 8px;
  vertical-align: top;
}

.fcd-today { background: #E6F1FB; }

.fcd-date { font-size: 10px; color: #888; }
.fcd-text { font-size: 10px; color: #666; max-width: 40px; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.fcd-temp { display: flex; gap: 4px; }
.fcd-t-max { font-size: 11px; font-weight: 500; color: #222; }
.fcd-t-min { font-size: 11px; color: #999; }

.desc-card {
  background: #fff;
  border-radius: 10px;
  border: 0.5px solid #e8e5d8;
  padding: 12px;
  margin-bottom: 10px;
}

.desc-text {
  font-size: 12px;
  color: #666;
  line-height: 1.65;
  display: block;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}

.mtag {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 10px;
  border: 0.5px solid #e0dfd8;
  color: #888;
  background: #f5f4f0;
}

.ck-btn {
  background: #EAF3DE;
  border: 0.5px solid #97C459;
  border-radius: 8px;
  padding: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 500;
  color: #27500A;
}

.ck-btn .ti-map-pin-check { color: #3B6D11; }

.ck-done {
  background: #f5f4f0;
  border-color: #e0dfd8;
  color: #888;
}

/* 与首页一致色板 */
.bg-green  { background: #EAF3DE; border-color: #d5e8c0; }
.bg-teal   { background: #E1F5EE; }
.bg-purple { background: #EEEDFE; }
.bg-blue   { background: #E6F1FB; }
.bg-amber  { background: #FAEEDA; }
.bg-coral  { background: #FAECE7; }
.bg-gray   { background: #F1EFE8; }

.color-green  { color: #3B6D11; }
.color-teal   { color: #0F6E56; }
.color-purple { color: #534AB7; }
.color-blue   { color: #185FA5; }
.color-amber  { color: #854F0B; }
.color-coral  { color: #993C1D; }
.color-gray   { color: #5F5E5A; }

.icon-xs { font-size: 10px; }
.icon-s  { font-size: 13px; }
.icon-m  { font-size: 16px; }
.icon-hero { font-size: 36px; opacity: 0.35; }

.hbtn-share {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: 1;
  width: 28px;
  height: 28px;
  border: none;
}

.hbtn-share::after { border: none; }
